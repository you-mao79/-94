# 依赖目录（体积最大，必须忽略）
node_modules/

# 环境变量文件（包含敏感信息）
.env
.env.local
.env.*.local

# 构建输出目录（编译后的文件）
dist/
build/
out/
.next/
.nuxt/

# 日志文件
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# 测试覆盖率报告
coverage/
.nyc_output/

# 缓存文件
.cache/
.parcel-cache/
.turbo/

# IDE 配置文件（根据自己使用的 IDE 选择性保留）
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath

# 操作系统生成文件
.DS_Store
Thumbs.db
desktop.ini

# 打包文件
*.tgz
*.tar.gz

# 临时文件
tmp/
temp/

# 本地调试产生的文件
*.local.json
*.local.yaml
